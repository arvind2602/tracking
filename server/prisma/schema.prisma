generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model organiation {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime?  @updatedAt
  showBanner     Boolean    @default(false)
  logo           String?
  showLoginPopup Boolean?   @default(false)
  notes          Note[]
  Site           Site[]
  employees      employee[]
  projects       projects[]

  @@index([name])
}

model employee {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName        String
  lastName         String
  email            String
  position         String
  role             role
  createdAt        DateTime       @default(now())
  updatedAt        DateTime?      @updatedAt
  is_archived      Boolean        @default(false)
  organiationId    String         @db.Uuid
  password         String
  lastDeviceId     String?
  responsibilities String[]       @default([])
  skills           String[]       @default([])
  bloodGroup       String?
  dob              DateTime?
  image            String?
  phoneNumber      String?
  joiningDate      DateTime?
  emergencyContact String?
  address          String?
  authoredNotes    Note[]         @relation("NoteAuthor")
  noteTags         NoteTag[]      @relation("NoteTagged")
  taskAssignees    TaskAssignee[]
  TimeLog          TimeLog[]
  comments         comment[]
  organiation      organiation    @relation(fields: [organiationId], references: [id])
  headedProjects   projects[]     @relation("ProjectHead")

  @@index([organiationId, is_archived])
  @@index([organiationId, role])
  @@index([email])
}

model projects {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String
  startDate      DateTime
  createdAt      DateTime             @default(now())
  updatedAt      DateTime?            @updatedAt
  organiationId  String               @db.Uuid
  is_archived    Boolean              @default(false)
  endDate        DateTime?
  priority_order Int?                 @default(0)
  headId         String?              @db.Uuid
  status         ProjectStatus        @default(ACTIVE)
  notes          Note[]
  holdHistory    ProjectHoldHistory[]
  head           employee?            @relation("ProjectHead", fields: [headId], references: [id])
  organiation    organiation          @relation(fields: [organiationId], references: [id])
  task           task[]

  @@index([organiationId, is_archived])
  @@index([organiationId, priority_order])
  @@index([organiationId, status])
}

model ProjectHoldHistory {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String    @db.Uuid
  startDate DateTime  @default(now())
  endDate   DateTime?
  reason    String?
  createdAt DateTime  @default(now())
  project   projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model task {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description String
  status      String
  createdBy   String
  assignedTo  String?
  assigned_at DateTime?
  points      Float
  createdAt   DateTime       @default(now())
  updatedAt   DateTime?      @updatedAt
  projectId   String         @db.Uuid
  dueDate     DateTime?
  order       Int            @default(0)
  priority    Priority       @default(MEDIUM)
  completedAt DateTime?
  parentId    String?        @db.Uuid
  type        TaskType       @default(SINGLE)
  assignees   TaskAssignee[]
  comments    comment[]
  parent      task?          @relation("SubTasks", fields: [parentId], references: [id])
  subtasks    task[]         @relation("SubTasks")
  project     projects       @relation(fields: [projectId], references: [id])

  @@index([projectId, status], map: "idx_task_project_status")
  @@index([assignedTo, status, updatedAt(sort: Desc)], map: "idx_task_assigned_status")
  @@index([projectId], map: "idx_task_project")
  @@index([projectId, order, createdAt(sort: Desc)], map: "idx_task_project_order")
  @@index([parentId], map: "idx_task_parent")
}

model TaskAssignee {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId      String    @db.Uuid
  employeeId  String    @db.Uuid
  order       Int?
  isCompleted Boolean   @default(false)
  assignedAt  DateTime? @default(now())
  completedAt DateTime?
  employee    employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task        task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, employeeId])
  @@index([taskId])
  @@index([employeeId])
}

model comment {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content     String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime?           @updatedAt
  taskId      String              @db.Uuid
  authorId    String              @db.Uuid
  attachments CommentAttachment[]
  links       CommentLink[]
  author      employee            @relation(fields: [authorId], references: [id])
  task        task                @relation(fields: [taskId], references: [id])

  @@index([authorId], map: "idx_comment_author")
  @@index([taskId, createdAt(sort: Desc)], map: "idx_comment_task")
}

model CommentAttachment {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String  @db.Uuid
  name      String
  url       String
  fileType  String
  size      Int?
  heading   String?
  comment   comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model CommentLink {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String  @db.Uuid
  name      String
  url       String
  heading   String?
  comment   comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model Site {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  latitude       Float
  longitude      Float
  organizationId String      @db.Uuid
  createdAt      DateTime    @default(now())
  updatedAt      DateTime?
  organiation    organiation @relation(fields: [organizationId], references: [id])
}

model TimeLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String    @db.Uuid
  checkIn    DateTime  @default(now())
  checkOut   DateTime?
  type       LogType   @default(WORK)
  reason     String?
  latitude   Float?
  longitude  Float?
  deviceId   String?
  deviceType String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime?
  employee   employee  @relation(fields: [employeeId], references: [id])
}

model Note {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  type           NoteType
  organizationId String           @db.Uuid
  authorId       String           @db.Uuid
  projectId      String?          @db.Uuid
  isPinned       Boolean          @default(false)
  pinUntil       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime?        @updatedAt
  content        String[]         @default([])
  author         employee         @relation("NoteAuthor", fields: [authorId], references: [id])
  organization   organiation      @relation(fields: [organizationId], references: [id])
  project        projects?        @relation(fields: [projectId], references: [id])
  attachments    NoteAttachment[]
  links          NoteLink[]
  tags           NoteTag[]

  @@index([organizationId, type])
  @@index([authorId])
  @@index([projectId])
  @@index([isPinned, organizationId])
}

model NoteAttachment {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteId   String  @db.Uuid
  name     String
  url      String
  fileType String
  size     Int?
  heading  String?
  note     Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}

model NoteLink {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteId  String  @db.Uuid
  name    String
  url     String
  heading String?
  note    Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
}

model NoteTag {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteId     String   @db.Uuid
  employeeId String   @db.Uuid
  employee   employee @relation("NoteTagged", fields: [employeeId], references: [id], onDelete: Cascade)
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, employeeId])
  @@index([noteId])
  @@index([employeeId])
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum role {
  ADMIN
  USER
}

enum LogType {
  WORK
  LUNCH
  BREAK
  WASHROOM
  PERSONAL_EMERGENCY
  HOME
  OTHER
}

enum TaskType {
  SINGLE
  SHARED
  SEQUENTIAL
}

enum NoteType {
  PERSONAL
  ORGANIZATIONAL
  PROJECT
}
