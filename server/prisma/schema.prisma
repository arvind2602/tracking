generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model organiation {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime?              @updatedAt
  showBanner            Boolean                @default(false)
  logo                  String?
  showLoginPopup        Boolean?               @default(false)
  geofencingEnabled     Boolean?               @default(false) // Toggle for geofencing
  weekOffs              String[]               @default(["Sunday"])
  holidays              Json[]                 @default([]) // [{date: '2024-01-01', name: 'New Year'}]
  wfhEnabled            Boolean?               @default(false)
  notes                 Note[]
  employees             employee[]
  projects              projects[]
  shifts                Shift[]
  geofences             Geofence[]
  organizationGeofences OrganizationGeofence[]
  qrLocations           QRLocation[]
  buildings             Building[]
  leaves                Leave[]

  @@index([name])
}

model employee {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName        String
  lastName         String
  email            String
  position         String
  role             role
  createdAt        DateTime        @default(now())
  updatedAt        DateTime?       @updatedAt
  is_archived      Boolean         @default(false)
  organiationId    String          @db.Uuid
  password         String
  lastDeviceId     String?
  responsibilities String[]        @default([])
  skills           String[]        @default([])
  bloodGroup       String?
  dob              DateTime?
  image            String?
  phoneNumber      String?
  joiningDate      DateTime?
  emergencyContact String?
  address          String?
  authoredNotes    Note[]          @relation("NoteAuthor")
  noteTags         NoteTag[]       @relation("NoteTagged")
  taskAssignees    TaskAssignee[]
  comments         comment[]
  organiation      organiation     @relation(fields: [organiationId], references: [id])
  headedProjects   projects[]      @relation("ProjectHead")
  devices          Device[]
  attendances      Attendance[]
  employeeShifts   EmployeeShift[]
  qrVisits         QRVisit[]
  leaves           Leave[]

  @@index([organiationId, is_archived])
  @@index([organiationId, role])
  @@index([email])
}

model projects {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String
  startDate      DateTime
  createdAt      DateTime             @default(now())
  updatedAt      DateTime?            @updatedAt
  organiationId  String               @db.Uuid
  is_archived    Boolean              @default(false)
  endDate        DateTime?
  priority_order Int?                 @default(0)
  headId         String?              @db.Uuid
  status         ProjectStatus        @default(ACTIVE)
  notes          Note[]
  holdHistory    ProjectHoldHistory[]
  head           employee?            @relation("ProjectHead", fields: [headId], references: [id])
  organiation    organiation          @relation(fields: [organiationId], references: [id])
  task           task[]

  @@index([organiationId, is_archived])
  @@index([organiationId, priority_order])
  @@index([organiationId, status])
}

model ProjectHoldHistory {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String    @db.Uuid
  startDate DateTime  @default(now())
  endDate   DateTime?
  reason    String?
  createdAt DateTime  @default(now())
  project   projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_hold_history")
}

model task {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description String
  status      String
  createdBy   String
  assignedTo  String?
  assigned_at DateTime?
  points      Float
  createdAt   DateTime       @default(now())
  updatedAt   DateTime?      @updatedAt
  projectId   String         @db.Uuid
  dueDate     DateTime?
  order       Int            @default(0)
  priority    Priority       @default(MEDIUM)
  completedAt DateTime?
  parentId    String?        @db.Uuid
  type        TaskType       @default(SINGLE)
  assignees   TaskAssignee[]
  comments    comment[]
  parent      task?          @relation("SubTasks", fields: [parentId], references: [id])
  subtasks    task[]         @relation("SubTasks")
  project     projects       @relation(fields: [projectId], references: [id])

  @@index([projectId, status], map: "idx_task_project_status")
  @@index([assignedTo, status, updatedAt(sort: Desc)], map: "idx_task_assigned_status")
  @@index([projectId], map: "idx_task_project")
  @@index([projectId, order, createdAt(sort: Desc)], map: "idx_task_project_order")
  @@index([parentId], map: "idx_task_parent")
}

model TaskAssignee {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId      String    @db.Uuid
  employeeId  String    @db.Uuid
  order       Int?
  isCompleted Boolean   @default(false)
  assignedAt  DateTime? @default(now())
  completedAt DateTime?
  employee    employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task        task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, employeeId])
  @@index([taskId])
  @@index([employeeId])
  @@map("task_assignee")
}

model comment {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content     String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime?           @updatedAt
  taskId      String              @db.Uuid
  authorId    String              @db.Uuid
  attachments CommentAttachment[]
  links       CommentLink[]
  author      employee            @relation(fields: [authorId], references: [id])
  task        task                @relation(fields: [taskId], references: [id])

  @@index([authorId], map: "idx_comment_author")
  @@index([taskId, createdAt(sort: Desc)], map: "idx_comment_task")
}

model CommentAttachment {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String  @db.Uuid
  name      String
  url       String
  fileType  String
  size      Int?
  heading   String?
  comment   comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("comment_attachment")
}

model CommentLink {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String  @db.Uuid
  name      String
  url       String
  heading   String?
  comment   comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("comment_link")
}

model Note {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  type           NoteType
  organizationId String           @db.Uuid
  authorId       String           @db.Uuid
  projectId      String?          @db.Uuid
  isPinned       Boolean          @default(false)
  pinUntil       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime?        @updatedAt
  content        String[]         @default([])
  author         employee         @relation("NoteAuthor", fields: [authorId], references: [id])
  organization   organiation      @relation(fields: [organizationId], references: [id])
  project        projects?        @relation(fields: [projectId], references: [id])
  attachments    NoteAttachment[]
  links          NoteLink[]
  tags           NoteTag[]

  @@index([organizationId, type])
  @@index([authorId])
  @@index([projectId])
  @@index([isPinned, organizationId])
  @@map("note")
}

model NoteAttachment {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteId   String  @db.Uuid
  name     String
  url      String
  fileType String
  size     Int?
  heading  String?
  note     Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@map("note_attachment")
}

model NoteLink {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteId  String  @db.Uuid
  name    String
  url     String
  heading String?
  note    Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@map("note_link")
}

model NoteTag {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteId     String   @db.Uuid
  employeeId String   @db.Uuid
  employee   employee @relation("NoteTagged", fields: [employeeId], references: [id], onDelete: Cascade)
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, employeeId])
  @@index([noteId])
  @@index([employeeId])
  @@map("note_tag")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum role {
  ADMIN
  USER
}

enum LogType {
  WORK
  LUNCH
  BREAK
  WASHROOM
  PERSONAL_EMERGENCY
  HOME
  OTHER
}

enum TaskType {
  SINGLE
  SHARED
  SEQUENTIAL
}

enum NoteType {
  PERSONAL
  ORGANIZATIONAL
  PROJECT
  TODO
  LEAVE // For leave requests - employee tags admins
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  WFH
  LEAVE
  HOLIDAY
}

model Device {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId    String // Device fingerprint or identifier
  deviceName  String?
  deviceType  String? // mobile, desktop, tablet
  browser     String?
  os          String?
  isActive    Boolean      @default(true)
  isPrimary   Boolean      @default(false)
  employeeId  String       @db.Uuid
  createdAt   DateTime     @default(now())
  lastUsedAt  DateTime?    @updatedAt
  employee    employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([deviceId, employeeId])
  @@index([employeeId, isPrimary])
  @@index([deviceId])
  @@map("device")
}

model Attendance {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String           @db.Uuid
  date           DateTime         @db.Date
  checkIn        DateTime?        @default(now())
  checkOut       DateTime?
  status         AttendanceStatus @default(PRESENT)
  latitude       Float?
  longitude      Float?
  location       String?
  ipAddress      String?
  deviceId       String?
  deviceName     String?
  workHours      Float? // calculated hours
  lateBy         Int? // minutes late
  shiftId        String?          @db.Uuid
  notes          String?
  deviceMismatch Boolean          @default(false)
  withinGeofence Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime?        @updatedAt
  employee       employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift          Shift?           @relation(fields: [shiftId], references: [id])
  geofence       Geofence?        @relation(fields: [geofenceId], references: [id])
  geofenceId     String?          @db.Uuid
  // device         Device?          @relation(fields: [deviceId], references: [id])
  // Commenting out conflicting relation for now to allow push

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@index([date])
  @@index([status])
  @@index([shiftId])
  @@map("attendance")
}

model Shift {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String // e.g., Morning, Evening, Night
  startTime      String // HH:mm format (e.g., "09:00")
  endTime        String // HH:mm format (e.g., "18:00")
  gracePeriod    Int             @default(15) // minutes late before marking as late
  officeHours    Float           @default(8) // expected hours per day
  isActive       Boolean         @default(true)
  organizationId String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?       @updatedAt
  organization   organiation     @relation(fields: [organizationId], references: [id])
  attendance     Attendance[]
  employeeShifts EmployeeShift[]

  @@index([organizationId])
  @@map("shift")
}

model EmployeeShift {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId String   @db.Uuid
  shiftId    String   @db.Uuid
  employee   employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift      Shift    @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, shiftId])
  @@index([employeeId])
  @@index([shiftId])
  @@map("employeeshift")
}

model Geofence {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  latitude              Float
  longitude             Float
  radius                Float // in meters
  isActive              Boolean                @default(true)
  organizationId        String                 @db.Uuid
  createdAt             DateTime               @default(now())
  updatedAt             DateTime?              @updatedAt
  organization          organiation            @relation(fields: [organizationId], references: [id])
  attendance            Attendance[]
  organizationGeofences OrganizationGeofence[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("geofence")
}

model OrganizationGeofence {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String      @db.Uuid
  geofenceId     String      @db.Uuid
  isEnabled      Boolean     @default(false)
  organization   organiation @relation(fields: [organizationId], references: [id])
  geofence       Geofence    @relation(fields: [geofenceId], references: [id])

  @@unique([organizationId, geofenceId])
  @@index([geofenceId])
  @@map("organizationgeofence")
}

model QRLocation {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  latitude       Float
  longitude      Float
  radius         Float       @default(50) // meters
  organizationId String      @db.Uuid
  zoneId         String?     @unique @db.Uuid // Optional link to indoor hierarchy
  createdAt      DateTime    @default(now())
  updatedAt      DateTime?   @updatedAt
  organization   organiation @relation(fields: [organizationId], references: [id])
  zone           Zone?       @relation(fields: [zoneId], references: [id])
  visits         QRVisit[]

  @@index([organizationId])
  @@map("qr_location")
}

model Building {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  address        String?
  latitude       Float
  longitude      Float
  organizationId String      @db.Uuid
  organization   organiation @relation(fields: [organizationId], references: [id])
  floors         Floor[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime?   @updatedAt

  @@index([organizationId])
  @@map("building")
}

model Floor {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level       Int
  name        String
  mapImageUrl String?   @db.Text
  buildingId  String    @db.Uuid
  building    Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  zones       Zone[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  @@index([buildingId])
  @@map("floor")
}

model Zone {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  type       ZoneType    @default(WORKSPACE)
  x          Float // Relative X on Floor Plan (0-100)
  y          Float // Relative Y on Floor Plan (0-100)
  floorId    String      @db.Uuid
  floor      Floor       @relation(fields: [floorId], references: [id], onDelete: Cascade)
  qrLocation QRLocation?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime?   @updatedAt

  @@index([floorId])
  @@map("zone")
}

enum ZoneType {
  MEETING_ROOM
  WORKSPACE
  CAFETERIA
  HALLWAY
  ENTRY_EXIT
  OTHER
}

model QRVisit {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId     String     @db.Uuid
  employeeId     String     @db.Uuid
  deviceId       String
  timestamp      DateTime   @default(now())
  userLat        Float
  userLng        Float
  distance       Float // distance from location in meters
  isValid        Boolean    @default(true)
  deviceMismatch Boolean    @default(false)
  location       QRLocation @relation(fields: [locationId], references: [id])
  employee       employee   @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([locationId])
  @@map("qr_visit")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Leave {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId     String      @db.Uuid
  organizationId String      @db.Uuid
  startDate      DateTime    @db.Date
  endDate        DateTime    @db.Date
  type           String // e.g., Sick, Casual, Earned
  reason         String
  status         LeaveStatus @default(PENDING)
  adminNote      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime?   @updatedAt
  employee       employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   organiation @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
  @@map("leave")
}
